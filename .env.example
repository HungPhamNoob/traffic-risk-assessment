ENV=local
STORAGE_TYPE=local
PROJECT_ROOT=.

# ==================== LOCAL SERVICE CONFIG ====================
NODE1_INTERNAL_IP=127.0.0.1
NODE2_INTERNAL_IP=127.0.0.1
NODE3_INTERNAL_IP=127.0.0.1

# ==================== DATABASE: LOCAL POSTGRES/POSTGIS ====================
POSTGRES_USER=capstone
POSTGRES_PASSWORD=123
POSTGRES_DB=capstone_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_PREDICTION_TABLE=traffic_risk_predictions
POSTGRES_US_PREDICTION_TABLE=traffic_risk_predictions
POSTGRES_TOMTOM_TABLE=traffic_tomtom_incidents
POSTGRES_ERROR_TABLE=streaming_processing_errors

# ==================== REDIS ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
REDIS_TIMEOUT_MS=2000

# ==================== KAFKA TOPICS ====================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093,localhost:9094
KAFKA_TOPIC_RAW=traffic.us.raw
KAFKA_TOPIC_TOMTOM_RAW=traffic.tomtom.raw

# ==================== LOCAL DATA PATHS ====================
US_RAW_PATH=data/raw/US.csv
US_TRAIN_OFFLINE_PATH=data/process/us_train_offline_before_2020.csv
US_PIPELINE_REPLAY_PATH=data/split/us_pipeline_from_2020.csv
OFFLINE_TRAIN_INPUT=data/split/us_train_offline_before_2020.csv
OFFLINE_TRAIN_OUTPUT=data/process/us_train_offline_before_2020.csv

SPLIT_YEAR=2020
PROCESSED_DATA_DIR=data/process
SIMULATION_DATA_DIR=data/simulation
SILVER_FEATURES_PATH=data/simulation/silver/flink_features
SILVER_FLUSH_EVERY_N=250
GOLD_FEATURES_PATH=data/simulation/gold/features
GOLD_RETRAIN_PATH=data/simulation/gold/features/retrain
GOLD_RETRAIN_PARQUET_PATH=data/simulation/gold/features/retrain/parquet
GOLD_RETRAIN_CSV_PATH=data/simulation/gold/features/retrain/csv
SPARK_OUTPUT_PATH=data/simulation/gold/features

# ==================== SPARK ====================
SPARK_MASTER_URL=spark://localhost:7077
SPARK_CHECKPOINT_DIR=data/simulation/checkpoints/spark
SPARK_HISTORICAL_OUTPUT_PATH=data/simulation/gold/features/historical
SPARK_REPLAY_OUTPUT_PATH=data/simulation/gold/features/replay
SPARK_WRITE_PARTITIONS=3
SPARK_WORKER_COUNT=3
SPARK_WORKER_CORES=1
SPARK_WORKER_MEMORY=768m

# ==================== FLINK ====================
FLINK_JOBMANAGER_HOST=localhost
FLINK_CHECKPOINT_INTERVAL=30000
FLINK_CHECKPOINT_DIR=file://data/simulation/checkpoints/flink
FLINK_CONSUMER_GROUP=flink-us-streaming
FLINK_INFERENCE_GROUP=flink-us-inference
FLINK_TOMTOM_GROUP=flink-tomtom-inference
FLINK_PARALLELISM=4

# ==================== MLFLOW / MODEL ====================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_ROOT=data/simulation/mlflow-artifacts
MLFLOW_EXPERIMENT_NAME=traffic-risk-assessment
MLFLOW_SERVING_ENDPOINT=http://localhost:5001/invocations
ML_MODEL_NAME=traffic-risk-model
ML_MODEL_VERSION=
ML_TIMEOUT_SECONDS=5
ML_FALLBACK_RISK_SCORE=-1

# ==================== H2O TRAINING ====================
H2O_MAX_RUNTIME=120
H2O_MAX_MEM=2G
H2O_NTHREADS=2
H2O_SEED=42
H2O_USE_CLASS_SAMPLING_FACTORS=true
H2O_MAX_CLASS_SAMPLING_FACTOR=100.0

# ==================== STREAMING PRODUCER ====================
SIMULATED_PRODUCER_ENABLED=true
SIMULATED_SOURCE=us_replay
SIMULATED_REPLAY_PATH=data/split/us_pipeline_from_2020.csv
STREAM_SPLIT_YEAR=2020
STREAM_MAX_RECORDS=1000
STREAM_THROTTLE_SECONDS=0.0
PRODUCER_FLUSH_EVERY_N_RECORDS=500

TOTAL_PRODUCERS=3
PRODUCER_MAX_BUFFER_MESSAGES=100000
PRODUCER_LINGER_MS=50
PRODUCER_BATCH_NUM_MESSAGES=10000
PRODUCER_COMPRESSION_TYPE=lz4
PRODUCER_QUEUE_BACKOFF_SECONDS=0.5

# ==================== TOMTOM STREAMING: US INCIDENT DETAILS ====================
TOMTOM_API=
TOMTOM_API_KEY=
TOMTOM_ENDPOINT=https://api.tomtom.com/traffic/services/5/incidentDetails
TOMTOM_BBOX=-74.25909,40.477399,-73.700181,40.917577
TOMTOM_BBOXES=US:New_York:-74.25909,40.477399,-73.700181,40.917577
TOMTOM_LANGUAGE=en-US
TOMTOM_TIME_VALIDITY=present
TOMTOM_FIELDS={incidents{type,geometry{type,coordinates},properties{id,iconCategory,magnitudeOfDelay,events{description,code,iconCategory},startTime,endTime,from,to,length,delay,roadNumbers,timeValidity,probabilityOfOccurrence,numberOfReports,lastReportTime}}}
TOMTOM_REQUEST_TIMEOUT_SECONDS=20
TOMTOM_POLL_SECONDS=60
TOMTOM_RUN_ONCE=false
STREAMING_WEATHER_ENRICHMENT_ENABLED=true
OPEN_METEO_ENDPOINT=https://api.open-meteo.com/v1/forecast
OPEN_METEO_TIMEOUT_SECONDS=5

# ==================== AIRFLOW ====================
AIRFLOW_FERNET_KEY=123
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=123

# ==================== MONITORING AND LOGGING ====================
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
DASHBOARD_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
PROMETHEUS_RETENTION_DAYS=7
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=123
STREAMING_LOG_LEVEL=INFO

# ==================== DOCKER COMPOSE ====================
COMPOSE_PROJECT_NAME=traffic-local
COMPOSE_FILE=docker-compose.yaml
