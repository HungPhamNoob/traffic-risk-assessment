# ============================================================
# Template .env — Copy file này thành .env và điền thông tin thực
# File .env KHÔNG được push lên GitHub (đã có trong .gitignore)
# ============================================================


# ── 3 Bucket riêng cho từng layer ────────────────────────────
GCS_BRONZE_BUCKET=big-data-group-4-bronze
GCS_SILVER_BUCKET=big-data-group-4-silver
GCS_GOLD_BUCKET=big-data-group-4-gold

# ── Đường dẫn chính xác đến file CSV trên GCS ────────────────
UK_BRONZE_PATH=gs://big-data-group-4-bronze/Road Safety Data - Collisions - last 5 years.csv
US_BRONZE_PATH=
TOMTOM_BRONZE_PATH=gs://big-data-group-4-bronze/tomtom_incidents/*.json

# ==================== GCP CONFIG ====================
GCP_PROJECT_ID=capstone-team4
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GCP_SERVICE_ACCOUNT_KEY=path/to/key.json
GOOGLE_APPLICATION_CREDENTIALS=/home/user/spark-gcs-key.json

# ==================== NODE CONFIG ====================
NODE1_INTERNAL_IP=10.128.0.2
NODE2_INTERNAL_IP=10.128.0.3
NODE3_INTERNAL_IP=10.128.0.4

# ==================== DATABASE ====================
POSTGRES_USER=capstone
POSTGRES_PASSWORD=changeme123
POSTGRES_DB=capstone_db
POSTGRES_HOST=10.128.0.2
POSTGRES_PORT=5432
DATABASE_URL=postgresql://capstone:changeme123@10.128.0.2:5432/capstone_db


# ==================== REDIS ====================
REDIS_URL=redis://10.128.0.3:6379/0

# ==================== KAFKA ====================
KAFKA_BOOTSTRAP_SERVERS=10.128.0.3:9092
KAFKA_TOPIC_TRANSACTIONS=transactions
KAFKA_TOPIC_ENRICHED=enriched-transactions
# Streaming topics
KAFKA_TOPIC_RAW=tomtom.traffic.raw
KAFKA_TOPIC_ENRICHED=traffic.events.enriched
KAFKA_TOPIC_PREDICTIONS=traffic.risk.predictions
KAFKA_TOPIC_DLQ=streaming.dlq
KAFKA_TOPIC_SIMULATION=simulation.control

# ==================== SPARK ====================
SPARK_JARS_DIR=/opt/spark/jars
HOTSPOT_DENSITY_THRESHOLD=0.3
SPARK_MASTER_URL=spark://10.128.0.4:7077
SPARK_CHECKPOINT_DIR=gs://capstone-data-lake/checkpoints/spark/

# ==================== FLINK ====================
FLINK_JOBMANAGER_HOST=10.128.0.3
FLINK_CHECKPOINT_INTERVAL=30000
FLINK_CHECKPOINT_DIR=/tmp/flink-checkpoints
FLINK_CONSUMER_GROUP=flink-streaming
FLINK_INFERENCE_GROUP=flink-inference

MLFLOW_SERVING_ENDPOINT=http://10.128.0.2:5000/invocations
ML_MODEL_NAME=risk-predictor
ML_MODEL_VERSION=
ML_TIMEOUT_SECONDS=5
ML_FALLBACK_RISK_SCORE=-1
POSTGIS_SINK_ENABLED=false
# ==================== MLFLOW ====================
MLFLOW_TRACKING_URI=http://10.128.0.2:5000
MLFLOW_ARTIFACT_ROOT=gs://capstone-data-lake/mlflow-artifacts/

# ==================== MINIO/GCS ====================
STORAGE_TYPE=gcs  # hoặc minio cho local dev
GCS_BUCKET=capstone-data-lake
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ==================== AIRFLOW ====================
AIRFLOW_FERNET_KEY=Your32CharFernetKeyHere!!
AIRFLOW__CORE__FERNET_KEY=Your32CharFernetKeyHere!!
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin

# ==================== MONITORING ====================
PROMETHEUS_RETENTION_DAYS=7
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme123
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme123
PROMETHEUS_ENABLED=false
STREAMING_LOG_LEVEL=INFO

# ==================== ALERTING ====================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
ALERT_EMAIL=team4-capstone@xxx.com

# ==================== APP ====================
GCS_BUCKET_GOLD=big-data-group-4-gold
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ENVIRONMENT=development

# ==================== STREAMING PRODUCER ====================
SIMULATED_PRODUCER_ENABLED=true
TOMTOM_PRODUCER_ENABLED=false
TOMTOM_API_KEY=
TOMTOM_ENDPOINT=https://api.tomtom.com/traffic/services/5/incidentDetails
TOMTOM_BBOX=
TOMTOM_BBOXES=US:New York:-74.25909,40.477399,-73.700181,40.917577;UK:London:-0.510375,51.28676,0.334015,51.691874
TOMTOM_LANGUAGE=en-US
TOMTOM_TIME_VALIDITY=present
PRODUCER_POLL_INTERVAL=60
PRODUCER_THROUGHPUT=10
SIMULATED_THROUGHPUT=10
SIMULATED_SOURCE=simulated
SIMULATED_REPLAY_PATH=data/sample/

# ==================== ENRICHMENT ====================
ENRICH_MIN_LAT=-90.0
ENRICH_MAX_LAT=90.0
ENRICH_MIN_LON=-180.0
ENRICH_MAX_LON=180.0
REDIS_HOST=10.128.0.3
REDIS_PORT=6379
REDIS_DB=0
REDIS_TIMEOUT_MS=2000
REDIS_TIMEOUT_MS=2000
WEATHER_ENRICHMENT_ENABLED=true
OPEN_METEO_ENDPOINT=https://api.open-meteo.com/v1/forecast
WEATHER_TIMEOUT_SECONDS=3
