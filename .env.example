# Cloud Storage
GCS_BUCKET=road-accident-data
GCS_PROJECT_ID=your-gcp-project

# Database
POSTGRES_HOST=node1-internal-ip
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=accident_risk

# Kafka
KAFKA_BROKERS=node2-internal-ip:9092
KAFKA_TOPIC_US=us-accidents
KAFKA_TOPIC_UK=uk-accidents
KAFKA_TOPIC_TOMTOM=tomtom-incidents

# APIs
TOMTOM_API_KEY=replace_with_real_key
OPENWEATHER_API_KEY=replace_with_real_key

# MLflow
MLFLOW_TRACKING_URI=http://node1-internal-ip:5000

# Redis (Side Input)
REDIS_HOST=node1-internal-ip
REDIS_PORT=6379

# Airflow
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
