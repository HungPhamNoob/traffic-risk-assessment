# ==================== GCP CONFIG ====================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# GCS Buckets
GCS_BUCKET_BRONZE=your-bronze-bucket
GCS_BUCKET_SILVER=your-silver-bucket
GCS_BUCKET_GOLD=your-gold-bucket
GCS_BUCKET_BACKUPS=your-backups-bucket
GCS_BUCKET_ML=your-ml-artifacts-bucket

# Authentication - Windows path (dùng forward slash)
GOOGLE_APPLICATION_CREDENTIALS=

# ==================== DATABASE ====================
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=your-db-name
DATABASE_URL=postgresql://your-db-user:your-db-password@postgres:5432/your-db-name

# ==================== AIRFLOW ====================
AIRFLOW__CORE__FERNET_KEY=your-32-characters-long-fernet-key
AIRFLOW_USER=your-airflow-user
AIRFLOW_PASSWORD=your-airflow-password
_AIRFLOW_WWW_USER_USERNAME=your-airflow-www-username
_AIRFLOW_WWW_USER_PASSWORD=your-airflow-www-password

# ==================== GRAFANA ====================
GRAFANA_USER=your-grafana-user
GRAFANA_PASSWORD=your-grafana-password
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password

# ==================== MLFLOW ====================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_GCS_BUCKET=your-ml-artifacts-bucket

# ==================== MONITORING ====================
PROMETHEUS_RETENTION_DAYS=7

# ==================== APP ====================
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","https://your-frontend-domain.com"]
ENVIRONMENT=development
